@model TechCore.Models.Employee

@{
    ViewData["Title"] = "Employee Details";
}

<h1 class="h3 mb-3">Employee Details</h1>

<dl class="row bg-white p-3 rounded-3 shadow-sm">
    <dt class="col-sm-3">Employee ID</dt>
    <dd class="col-sm-9">@Model.EmployeeId</dd>
    <dt class="col-sm-3">Name</dt>
    <dd class="col-sm-9">@Model.FullName</dd>
    <dt class="col-sm-3">Position</dt>
    <dd class="col-sm-9">@Model.Position</dd>
    <dt class="col-sm-3">Department</dt>
    <dd class="col-sm-9">@Model.Department</dd>
    <dt class="col-sm-3">Daily Rate</dt>
    <dd class="col-sm-9">@Model.DailyRate.ToString("C")</dd>
</dl>

<div class="d-flex gap-2">
    <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.EmployeeId">Edit</a>
    <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
</div>