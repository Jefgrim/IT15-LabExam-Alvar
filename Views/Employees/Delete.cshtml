@model TechCore.Models.Employee

@{
    ViewData["Title"] = "Delete Employee";
}

<div class="page-panel reveal-up mb-3">
    <p class="page-kicker">Danger Zone</p>
    <h1 class="h3 mb-1">Delete Employee</h1>
    <p class="page-subtitle">Review employee details before confirming this irreversible action.</p>
</div>

<div class="danger-panel p-3 p-md-4 reveal-up">
    <div class="alert alert-warning">Are you sure you want to delete this employee?</div>

    <dl class="row mb-3">
        <dt class="col-sm-3">Employee ID</dt>
        <dd class="col-sm-9">@Model.EmployeeId</dd>
        <dt class="col-sm-3">Name</dt>
        <dd class="col-sm-9">@Model.FullName</dd>
        <dt class="col-sm-3">Position</dt>
        <dd class="col-sm-9">@Model.Position</dd>
        <dt class="col-sm-3">Department</dt>
        <dd class="col-sm-9">@Model.Department</dd>
        <dt class="col-sm-3">Daily Rate</dt>
        <dd class="col-sm-9">@Model.DailyRate.ToString("C")</dd>
    </dl>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">@Html.ValidationSummary(false)</div>
}

    <form asp-action="Delete" method="post" class="d-flex gap-2">
        <input type="hidden" asp-for="EmployeeId" />
        <button type="submit" class="btn btn-danger">Delete Employee</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
    </form>
</div>