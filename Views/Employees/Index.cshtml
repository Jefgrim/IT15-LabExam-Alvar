@model IEnumerable<TechCore.Models.Employee>

@{
    ViewData["Title"] = "Employees";
    var totalEmployees = Model.Count();
    var departments = Model.Select(e => e.Department).Where(d => !string.IsNullOrWhiteSpace(d)).Distinct(StringComparer.OrdinalIgnoreCase).Count();
}

<div class="page-panel reveal-up mb-3">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <p class="page-kicker">People Directory</p>
            <h1 class="h3 mb-1">Employees</h1>
            <p class="page-subtitle">Manage employee records and daily rates.</p>
        </div>
        <div class="metric-chip-row">
            <span class="metric-chip"><strong>@totalEmployees</strong> total employees</span>
            <span class="metric-chip"><strong>@departments</strong> departments</span>
        </div>
    </div>
</div>

<div class="d-flex justify-content-end mb-3 reveal-up">
    <div>
        <a class="btn btn-primary" asp-action="Create">Add Employee</a>
    </div>
</div>

<div class="table-responsive reveal-up">
    <table class="table table-striped table-hover tc-table align-middle mb-0">
        <thead class="table-dark">
            <tr>
                <th>Employee ID</th>
                <th>Name</th>
                <th>Position</th>
                <th>Department</th>
                <th>Daily Rate</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var employee in Model)
        {
            <tr>
                <td>@employee.EmployeeId</td>
                <td>@employee.FullName</td>
                <td>@employee.Position</td>
                <td>@employee.Department</td>
                <td>@employee.DailyRate.ToString("C")</td>
                <td class="text-end">
                    <div class="button-cluster">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@employee.EmployeeId">Details</a>
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@employee.EmployeeId">Edit</a>
                        <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@employee.EmployeeId">Delete</a>
                        <a class="btn btn-sm btn-outline-dark" asp-controller="Payroll" asp-action="History" asp-route-employeeId="@employee.EmployeeId">History</a>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>