@using Microsoft.AspNetCore.Mvc.Rendering
@model IEnumerable<TechCore.Models.PayrollTransaction>

@{
    ViewData["Title"] = "Payroll";
    var recordCount = Model.Count();
    var totalGross = Model.Sum(p => p.GrossPay);
    var totalNet = Model.Sum(p => p.NetPay);
}

<div class="page-panel reveal-up mb-3">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <p class="page-kicker">Payroll Control</p>
            <h1 class="h3 mb-1">Payroll Transactions</h1>
            <p class="page-subtitle">View and manage payroll entries.</p>
        </div>
        <div class="metric-chip-row">
            <span class="metric-chip"><strong>@recordCount</strong> records</span>
            <span class="metric-chip"><strong>@totalGross.ToString("C0")</strong> gross</span>
            <span class="metric-chip"><strong>@totalNet.ToString("C0")</strong> net</span>
        </div>
    </div>
</div>

<div class="d-flex justify-content-end mb-3 reveal-up">
    <div>
        <a class="btn btn-primary" asp-action="Create">Add Payroll Record</a>
    </div>
</div>

<div class="action-card p-3 p-md-4 mb-3 reveal-up">
    <form method="get" class="row g-2 align-items-end">
        <div class="col-md-6">
            <label class="form-label">Filter by employee</label>
            <select class="form-select" name="employeeId" asp-items="@(ViewBag.Employees as IEnumerable<SelectListItem>)">
                <option value="">All Employees</option>
            </select>
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-outline-primary w-100">Apply Filter</button>
        </div>
    </form>
</div>

<div class="table-responsive reveal-up">
    <table class="table table-striped table-hover tc-table align-middle mb-0">
        <thead class="table-dark">
            <tr>
                <th>Payroll ID</th>
                <th>Employee</th>
                <th>Date</th>
                <th>Days Worked</th>
                <th>Gross Pay</th>
                <th>Deduction</th>
                <th>Net Pay</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var payroll in Model)
        {
            <tr>
                <td>@payroll.PayrollTransactionId</td>
                <td>@payroll.Employee?.FullName</td>
                <td>@payroll.Date.ToString("yyyy-MM-dd")</td>
                <td>@payroll.DaysWorked</td>
                <td>@payroll.GrossPay.ToString("C")</td>
                <td>@payroll.Deduction.ToString("C")</td>
                <td>@payroll.NetPay.ToString("C")</td>
                <td class="text-end">
                    <div class="button-cluster">
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@payroll.PayrollTransactionId">Edit</a>
                        <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@payroll.PayrollTransactionId">Delete</a>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>