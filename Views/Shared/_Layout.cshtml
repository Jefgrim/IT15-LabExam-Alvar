@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var isHome = string.Equals(currentController, "Home", StringComparison.OrdinalIgnoreCase);
    var isEmployees = string.Equals(currentController, "Employees", StringComparison.OrdinalIgnoreCase);
    var isPayroll = string.Equals(currentController, "Payroll", StringComparison.OrdinalIgnoreCase);
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TechCore Payroll</title>
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TechCore.styles.css" asp-append-version="true" />
</head>
<body class="app-body">
    <header class="app-header">
        <nav class="navbar navbar-expand-lg tc-navbar">
            <div class="container-fluid">
                <a class="navbar-brand d-flex flex-column" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="brand-title">TechCore Payroll</span>
                    <span class="brand-subtitle">Operations Dashboard</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between align-items-center">
                    <ul class="navbar-nav flex-grow-1 gap-lg-2">
                        <li class="nav-item">
                            <a class="nav-link @(isHome ? "active" : string.Empty)" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(isEmployees ? "active" : string.Empty)" asp-area="" asp-controller="Employees" asp-action="Index">Employees</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(isPayroll ? "active" : string.Empty)" asp-area="" asp-controller="Payroll" asp-action="Index">Payroll</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container app-shell">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer tc-footer text-muted">
        <div class="container">
            <div class="d-flex flex-column flex-md-row justify-content-between gap-2 py-3">
                <span>&copy; 2026 - TechCore Payroll System</span>
                <span class="small">Built for reliable employee and payroll operations</span>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
